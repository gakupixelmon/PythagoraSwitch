# ─── Supabase 接続設定（必須） ────────────────────────────────────────
# Supabase プロジェクトの「Settings > API」から取得する
# anon key は公開しても安全（RLS が全データを保護する）
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── アプリ設定 ──────────────────────────────────────────────────────
VITE_APP_NAME="3D ピタゴラスイッチ"

# ─── ※ 絶対に含めないもの ─────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY は絶対にフロントエンドに含めないこと！
# バックエンドサーバー（サーバーサイドのみ）で使用する場合のみ環境変数に設定する
